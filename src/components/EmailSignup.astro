---
interface Props {
  variant?: 'inline' | 'card';
}
const { variant = 'inline' } = Astro.props;

// Beehiiv hosted subscribe form. Public ID — fine to hardcode (it ships in
// HTML on every page either way). Swap this if we ever move providers.
const BEEHIIV_FORM_ID = 'cb16155f-528d-48f8-ab93-f676171d5eaf';
---
<div class={`email-signup email-signup--${variant}`}>
  <iframe
    src={`https://subscribe-forms.beehiiv.com/${BEEHIIV_FORM_ID}`}
    class="beehiiv-embed"
    data-test-id="beehiiv-embed"
    frameborder="0"
    scrolling="no"
    title="Subscribe to the newsletter"
    loading="lazy"
  ></iframe>
  <p class="email-signup-note">
    Or grab the <a href="/rss.xml">RSS feed</a> — same content, no email.
  </p>
</div>
<script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
