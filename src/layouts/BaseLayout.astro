---
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}
const { title, description, image, type = 'website', pubDate, updatedDate, tags } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : new URL('/og-default.png', Astro.site);
const cfBeaconToken = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Solo AI Guy',
  url: Astro.site?.toString(),
  description: 'Local-first AI for solo builders.',
};
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Solo AI Guy',
  url: Astro.site?.toString(),
  sameAs: [
    'https://www.youtube.com/@XiyoTec',
    'https://x.com/XiyoTec',
    'https://www.linkedin.com/in/xiyo-tec-a0818b406/',
    'https://www.instagram.com/xiyotec/',
    'https://www.tiktok.com/@xiyotec',
    'https://bsky.app/profile/xiyotec.bsky.social',
  ],
};
const articleSchema = type === 'article' && pubDate ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: ogImage.toString(),
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: 'Solo AI Guy' },
  publisher: { '@type': 'Organization', name: 'Solo AI Guy', url: Astro.site?.toString() },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
  ...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="impact-site-verification" value="0041527d-52a1-4105-a015-60558032e2e1" />
  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" type="application/rss+xml" title="Solo AI Guy" href="/rss.xml" />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  {cfBeaconToken && (
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
    />
  )}
</head>
<body>
  <header>
    <a href="/" class="brand">Solo AI Guy</a>
    <nav>
      <a href="/posts/">Posts</a>
      <a href="/about/">About</a>
      <a href="/now/">Now</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>Built solo with <a href="/atlas/">🦁 Atlas</a>. <a href="/rss.xml">Subscribe via RSS</a>.</p>
    <nav class="social" aria-label="Social channels">
      <a href="https://www.youtube.com/@XiyoTec" rel="me noopener" target="_blank">YouTube</a>
      <a href="https://x.com/XiyoTec" rel="me noopener" target="_blank">X</a>
      <a href="https://www.linkedin.com/in/xiyo-tec-a0818b406/" rel="me noopener" target="_blank">LinkedIn</a>
      <a href="https://www.instagram.com/xiyotec/" rel="me noopener" target="_blank">Instagram</a>
      <a href="https://www.tiktok.com/@xiyotec" rel="me noopener" target="_blank">TikTok</a>
      <a href="https://bsky.app/profile/xiyotec.bsky.social" rel="me noopener" target="_blank">Bluesky</a>
    </nav>
  </footer>
</body>
</html>
