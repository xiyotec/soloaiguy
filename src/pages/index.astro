---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Solo AI Guy — local-first AI for solo builders"
  description="Real configs, real benchmarks, and real costs of building AI projects on consumer hardware."
>
  <section>
    <h1>Local-first AI<br />for solo builders.</h1>
    <p>
      Real configs. Real benchmarks. Real costs. No enterprise budgets, no team of ML
      engineers, no $100/day API bills — just one developer building AI projects on
      a normal desktop and writing down what works.
    </p>
    <p>
      <a href="/posts/">Read the latest posts →</a>
    </p>
  </section>

  <section>
    <h2>Recent posts</h2>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`/posts/${post.id}/`}>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          </a>
        </li>
      ))}
    </ul>
    <p>
      <a href="/posts/">See all posts →</a>
    </p>
  </section>

  <section class="signup-section">
    <EmailSignup variant="card" />
  </section>
</BaseLayout>
